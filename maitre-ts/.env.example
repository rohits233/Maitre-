# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Public hostname used to build the wss:// media stream URL.
# In local dev, use your ngrok URL (without https://).
# Example: abc123.ngrok.io
HOST=<your-ngrok-url>

# ── Twilio ────────────────────────────────────────────────────────────────────
# In production these come from AWS Secrets Manager (SECRET_ARN).
# In local dev, set them here.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── DynamoDB table names (defaults match CDK stack) ───────────────────────────
RESERVATIONS_TABLE=Reservations
AVAILABILITY_SLOTS_TABLE=AvailabilitySlots
LOCATIONS_TABLE=Locations
VIP_LIST_TABLE=VIPList
CALL_FLOW_RULES_TABLE=CallFlowRules
VOICE_PERSONAS_TABLE=VoicePersonas
CALL_RECORDS_TABLE=CallRecords
IDEMPOTENCY_KEYS_TABLE=IdempotencyKeys
FEEDBACK_SURVEYS_TABLE=FeedbackSurveys

# ── Local development flags ───────────────────────────────────────────────────
# Set to true to use in-memory stores instead of DynamoDB
USE_LOCAL_DB=true

# ── Feature flags ─────────────────────────────────────────────────────────────
FEEDBACK_ENABLED=true
SMS_PROVIDER=twilio

# ── Drain timeout (ms) ────────────────────────────────────────────────────────
DRAIN_TIMEOUT_MS=120000

# ── Default location ──────────────────────────────────────────────────────────
DEFAULT_LOCATION_ID=default
